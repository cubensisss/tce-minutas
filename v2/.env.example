# =============================================================================
# Supabase (mesmo projeto do v1)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# =============================================================================
# Gemini (Google AI Studio API key)
# =============================================================================
GEMINI_API_KEY=AIza...
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# =============================================================================
# Vertex AI Search / Discovery Engine
# Usar GOOGLE_APPLICATION_CREDENTIALS_JSON em produção (Render env var = JSON inteiro)
# Em dev local apontar para o arquivo via GOOGLE_APPLICATION_CREDENTIALS
# =============================================================================
GCP_PROJECT_ID=uptemporada
GCP_LOCATION=global
VERTEX_DATA_STORE_ID=tceandressa_1775759460294
VERTEX_APP_ID=tceandressa_1775759242362
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# =============================================================================
# Auth — lista separada por vírgula com os e-mails autorizados
# (ALLOWED_USER_EMAIL singular ainda é honrado por compat)
# =============================================================================
ALLOWED_USER_EMAILS=usuario1@dominio.com,usuario2@dominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Observabilidade (opcional em dev)
# =============================================================================
SENTRY_DSN=
LOG_LEVEL=info
